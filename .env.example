# D1 API 配置示例
# 复制此文件为 .env.local 并填充实际值

# Worker URL - 部署到 Cloudflare 后的地址
# 示例: https://family-tree.wolfife.workers.dev
VITE_D1_API_BASE_URL=https://your-worker-url.workers.dev

# 服务端新增环境变量（在 Worker 侧配置，不在前端 .env 中使用）：
# - SYSADMIN_PASSWORD_PBKDF2: 推荐，格式 pbkdf2_sha256$100000$<salt_hex>$<hash_hex>
# - SYSADMIN_PASSWORD_PBKDF2_NEXT: 可选，用于密码轮换窗口
# - ALLOW_LEGACY_API_TOKEN_AUTH: 默认 false，仅紧急回滚时短期开启
# - SESSION_TTL_HOURS: 会话有效期小时数（默认 24）
