{
  "name": "family-tree-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean:wrangler": "node -e \"import('node:fs').then(fs=>fs.rmSync('.wrangler',{recursive:true,force:true}))\"",
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "npm run build && wrangler dev --remote",
    "preview:local": "npm run build && wrangler dev",
    "predeploy": "npm run clean:wrangler",
    "deploy": "npm run build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:part-data-v2": "tsx scripts/verify-part-data-v2.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.32.0",
    "echarts": "^5.6.0",
    "sql.js": "^1.14.1",
    "tesseract.js": "^5.1.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.2",
    "@types/node": "^22.13.10",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^0.20.0",
    "tsx": "^4.21.0",
    "typescript": "~5.7.3",
    "vite": "^6.2.2",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7",
    "wrangler": "^4.80.0"
  }
}
